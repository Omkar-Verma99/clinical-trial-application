rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isDoctorOwner(doc) {
      return isAuthenticated() && doc.doctorId == request.auth.uid;
    }
    
    // ===== UNIFIED PATIENTS COLLECTION =====
    // ONE document per patient with all data (patientInfo + baseline + followups)
    // OPTIMIZED: Single document read/write per patient
    // PERFORMANCE: 3-4x faster, 67% lower cost
    match /patients/{patientId} {
      function sectionLocked(section) {
        return resource.data.sectionLocks != null &&
          resource.data.sectionLocks[section] != null &&
          resource.data.sectionLocks[section].locked == true;
      }

      function patientInfoFieldsUnchanged() {
        return request.resource.data.patientCode == resource.data.patientCode &&
          request.resource.data.studySiteCode == resource.data.studySiteCode &&
          request.resource.data.investigatorName == resource.data.investigatorName &&
          request.resource.data.baselineVisitDate == resource.data.baselineVisitDate &&
          request.resource.data.age == resource.data.age &&
          request.resource.data.gender == resource.data.gender &&
          request.resource.data.height == resource.data.height &&
          request.resource.data.weight == resource.data.weight &&
          request.resource.data.bmi == resource.data.bmi &&
          request.resource.data.durationOfDiabetes == resource.data.durationOfDiabetes &&
          request.resource.data.baselineGlycemicSeverity == resource.data.baselineGlycemicSeverity &&
          request.resource.data.smokingStatus == resource.data.smokingStatus &&
          request.resource.data.alcoholIntake == resource.data.alcoholIntake &&
          request.resource.data.physicalActivityLevel == resource.data.physicalActivityLevel &&
          request.resource.data.diabetesComplications == resource.data.diabetesComplications &&
          request.resource.data.comorbidities == resource.data.comorbidities &&
          request.resource.data.previousTreatmentType == resource.data.previousTreatmentType &&
          request.resource.data.previousDrugClasses == resource.data.previousDrugClasses &&
          request.resource.data.reasonForTripleFDC == resource.data.reasonForTripleFDC;
      }

      function followupEntryAt(data, index) {
        return data.followups == null || data.followups.size() <= index ? null : data.followups[index];
      }

      function followupUnchanged(index) {
        return followupEntryAt(request.resource.data, index) == followupEntryAt(resource.data, index);
      }

      function doctorLockGuard() {
        return (!sectionLocked('patient_info') || patientInfoFieldsUnchanged()) &&
          (!sectionLocked('baseline') || request.resource.data.baseline == resource.data.baseline) &&
          (!sectionLocked('followup_1') || followupUnchanged(0)) &&
          (!sectionLocked('followup_2') || followupUnchanged(1)) &&
          (!sectionLocked('followup_3') || followupUnchanged(2));
      }

      // Doctors can see their own patients; admins can see all
      allow read: if isDoctorOwner(resource.data) || isAdmin();

      // Doctors create their own patients; doctorId must match auth
      allow create: if request.resource.data.doctorId == request.auth.uid;

      allow update: if isAdmin() ||
        (isDoctorOwner(resource.data) &&
        isDoctorOwner(request.resource.data) &&
        doctorLockGuard());

      allow delete: if isDoctorOwner(resource.data);
    }

    // ===== BASELINE DATA COLLECTION =====
    // Legacy/fallback support for baseline forms
    // Read-only, used by real-time sync listeners
    match /baselineData/{docId} {
      allow read: if resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) &&
        (isDoctorOwner(get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data) || isAdmin());
      
      allow create, update: if request.resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(request.resource.data.patientId)) &&
        isDoctorOwner(get(/databases/$(database)/documents/patients/$(request.resource.data.patientId)).data);
      
      allow delete: if resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) &&
        isDoctorOwner(get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data);
    }

    // ===== FOLLOWUP DATA COLLECTION =====
    // Legacy/fallback support for followup forms
    // Read-only, used by real-time sync listeners
    match /followUpData/{docId} {
      allow read: if resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) &&
        (isDoctorOwner(get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data) || isAdmin());
      
      allow create, update: if request.resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(request.resource.data.patientId)) &&
        isDoctorOwner(get(/databases/$(database)/documents/patients/$(request.resource.data.patientId)).data);
      
      allow delete: if resource.data.patientId != null &&
        exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) &&
        isDoctorOwner(get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data);
    }

    // ===== DOCTORS COLLECTION =====
    // Doctor profile information
    match /doctors/{doctorId} {
      allow read: if (isAuthenticated() && request.auth.uid == doctorId) || isAdmin();
      
      allow create: if isAuthenticated() &&
        request.auth.uid == doctorId;
      
      allow update: if isAuthenticated() && 
        request.auth.uid == doctorId;
      
      allow delete: if false; // Prevent accidental deletion
    }

    // ===== STUDY SITE CODE LOCKS =====
    // Enforces one doctor account per center/study code.
    match /studySiteCodes/{studySiteCode} {
      // Only authenticated users can read lock docs used during their signup transaction.
      allow read: if isAuthenticated();

      // Allow one-time create only for the currently authenticated user during signup.
      allow create: if isAuthenticated() &&
        request.resource.data.doctorId == request.auth.uid &&
        request.resource.data.studySiteCode == studySiteCode &&
        !exists(/databases/$(database)/documents/studySiteCodes/$(studySiteCode));

      // Lock records must remain immutable after creation.
      allow update, delete: if false;
    }

    // ===== ADMINS COLLECTION =====
    // Admin accounts and credentials (separate from doctors)
    match /admins/{adminId} {
      // Admins can read their own document only
      allow read: if isAuthenticated() && 
        request.auth.uid == adminId;
      
      // Only system/cloud functions can create admins
      allow create: if false;
      
      // Admins can update their own runtime metadata only.
      // Privileged fields (role, permissions, status, identity) are immutable from client SDK.
      allow update: if isAuthenticated() && 
        request.auth.uid == adminId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.permissions == resource.data.permissions &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.firstName == resource.data.firstName &&
        request.resource.data.lastName == resource.data.lastName;
      
      // Prevent admin deletion
      allow delete: if false;
    }

    // ===== FORM RESPONSES COLLECTION =====
    // All form submissions (baseline + followups)
    match /formResponses/{responseId} {
      // Doctors can read their own patient's forms; admins can read all
      allow read: if resource.data.doctorId == request.auth.uid || isAdmin();
      
      // Doctors can submit new forms for their patients
      allow create: if request.resource.data.doctorId == request.auth.uid &&
        exists(/databases/$(database)/documents/patients/$(request.resource.data.patientId)) &&
        get(/databases/$(database)/documents/patients/$(request.resource.data.patientId)).data.doctorId == request.auth.uid;
      
      // Doctors cannot modify submitted forms; admins read-only
      allow update: if false;
      allow delete: if false;
    }

    // ===== AUDIT LOGS COLLECTION =====
    // Track all admin actions (super admin only)
    match /auditLogs/{logId} {
      // Only super admins can view audit logs
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
      
      // Only cloud functions can write audit logs
      allow create, write, update, delete: if false;
    }

    // ===== EXPORTS COLLECTION =====
    // Track data exports
    match /exports/{exportId} {
      // Admins can read their own exports; super admins can read all
      allow read: if (resource.data.adminId == request.auth.uid && isAdmin()) ||
        (isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin');
      
      // Only cloud functions can create/modify exports
      allow create, write, update, delete: if false;
    }

    // ===== ADMIN PANEL COLLECTION =====
    // Admin panel settings and configuration
    match /adminPanel/{document=**} {
      // Only authenticated admins can access
      allow read: if isAdmin();
      allow write: if false; // Only system admin can modify
    }
  }
}
